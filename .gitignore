# Эта .gitignore должна находиться в корневой папке вашего Unity-проекта
# Основано на официальном шаблоне: https://github.com/github/gitignore/blob/main/Unity.gitignore
# Адаптировано для Unity 6 (2023.3+) и новее

# ============================================
# Основные папки с кэшем и временными файлами
# ============================================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# ============================================
# Папки с диагностикой (могут быть огромными)
# ============================================
/[Mm]emoryCaptures/
/[Rr]ecordings/

# ============================================
# Файлы метаданных (важно: сами .meta ассетов НЕ игнорируем)
# ============================================
# Игнорируем .meta только для временных/служебных файлов
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ============================================
# Файлы, генерируемые IDE (Visual Studio, Rider, VS Code)
# ============================================
# Решения и проекты (Unity генерирует их заново при необходимости)
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Visual Studio Code
.vscode/

# Rider (авто-генерируемый плагин)
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio
.vs/

# ============================================
# Результаты сборки и бинарные артефакты
# ============================================
# APK и AAB для Android
*.apk
*.aab

# iOS сборка
*.app

# Unity-пакеты
*.unitypackage

# Gradle (используется для Android-сборок)
.gradle/

# ============================================
# Системные и временные файлы
# ============================================
# Отчёты о падении Unity
sysinfo.txt
crashlytics-build.properties

# Mono временные файлы
mono_crash.*

# Blender (если используете .blend файлы)
*.blend1
*.blend1.meta

# ============================================
# Addressables (система управления контентом)
# ============================================
/ServerData/
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# ============================================
# Visual Scripting (бывший Bolt)
# ============================================
/[Aa]ssets/Unity.VisualScripting.Generated/

# ============================================
# Прочие временные файлы
# ============================================
*.tmp
*.log
.utmp/
ExportedObj/

# ============================================
# Файлы отладки (если не нужны в репозитории)
# ============================================
*.dmp
*.full

# ============================================
# Пользовательские настройки (обычно не коммитятся)
# ============================================
*.prefs
*.prefs.meta